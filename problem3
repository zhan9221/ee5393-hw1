#!/usr/bin/env python3
import random
import math
from collections import defaultdict

# ----------------------------
# Gillespie SSA for CRNs
# reaction: (reactants dict, products dict, rate k)
# propensity a = k * Π comb(n_i, stoich_i)
# ----------------------------

def comb(n, r):
    if n < r: return 0
    if r == 0: return 1
    if r == 1: return n
    # small r only in this homework (<=2), simple:
    if r == 2: return n*(n-1)//2
    # fallback
    out = 1
    for i in range(r):
        out = out * (n - i) // (i + 1)
    return out

def propensity(state, reactants, k):
    a = k
    for sp, sto in reactants.items():
        a *= comb(state[sp], sto)
        if a == 0:
            return 0
    return a

def fire(state, reactants, products):
    # consume
    for sp, sto in reactants.items():
        state[sp] -= sto
    # produce
    for sp, sto in products.items():
        state[sp] += sto

def gillespie(reactions, init_state, tmax=1e6, max_events=200000):
    state = defaultdict(int, init_state)
    t = 0.0
    events = 0

    while t < tmax and events < max_events:
        props = []
        a0 = 0.0
        for (R, P, k) in reactions:
            a = propensity(state, R, k)
            props.append(a)
            a0 += a

        if a0 <= 0:
            break

        r1 = random.random()
        r2 = random.random()
        tau = -math.log(r1) / a0
        t += tau

        # pick reaction
        threshold = r2 * a0
        s = 0.0
        mu = None
        for i, a in enumerate(props):
            s += a
            if s >= threshold:
                mu = i
                break

        fire(state, reactions[mu][0], reactions[mu][1])
        events += 1

    return dict(state), t, events

# ----------------------------
# Problem 3 Networks
# (A) Z = X * log2(Y)
# (B) Y = 2^(log2(X))
# ----------------------------

def network_log_of_Y_to_W():
    # Variables: y input, w output, b catalyst small>0
    # b -> a + b (slow)
    # a + 2y -> c + y' + a (faster)
    # 2c -> c (faster)
    # a -> ∅ (fast)
    # y' -> y (medium)
    # c -> w (medium)
    # Use ∅ as "nil" (not stored); implement by not adding products.
    return [
        ({"b":1}, {"a":1,"b":1}, 0.01),          # slow
        ({"a":1,"y":2}, {"c":1,"yp":1,"a":1}, 5.0),  # faster
        ({"c":2}, {"c":1}, 5.0),                # faster
        ({"a":1}, {}, 50.0),                    # fast
        ({"yp":1}, {"y":1}, 1.0),               # medium
        ({"c":1}, {"w":1}, 1.0),                # medium
    ]

def network_log_of_X_to_W():
    # Same log module but input is x
    return [
        ({"b":1}, {"a":1,"b":1}, 0.01),
        ({"a":1,"x":2}, {"c":1,"xp":1,"a":1}, 5.0),
        ({"c":2}, {"c":1}, 5.0),
        ({"a":1}, {}, 50.0),
        ({"xp":1}, {"x":1}, 1.0),
        ({"c":1}, {"w":1}, 1.0),
    ]

def network_multiply_X_and_W_to_Z():
    # x -> d
    # d + w -> d + z'
    # d -> ∅
    # z' -> z
    return [
        ({"x":1}, {"d":1}, 0.5),
        ({"d":1,"w":1}, {"d":1,"zp":1}, 5.0),
        ({"d":1}, {}, 10.0),
        ({"zp":1}, {"z":1}, 1.0),
    ]

def network_exponentiate_W_to_Y():
    # w -> e (slow-ish)
    # e + y -> e + 2y'
    # e -> ∅
    # y' -> y
    return [
        ({"w":1}, {"e":1}, 0.2),
        ({"e":1,"y":1}, {"e":1,"yp2":2}, 10.0),
        ({"e":1}, {}, 10.0),
        ({"yp2":1}, {"y":1}, 1.0),
    ]

def run_case_A(X0=6, Y0=32):
    reactions = []
    reactions += network_log_of_Y_to_W()
    reactions += network_multiply_X_and_W_to_Z()

    init = {"x":X0, "y":Y0, "b":2, "w":0, "z":0}
    final, t, ev = gillespie(reactions, init)
    return final, t, ev

def run_case_B(X0=32):
    reactions = []
    reactions += network_log_of_X_to_W()
    reactions += network_exponentiate_W_to_Y()

    init = {"x":X0, "b":2, "w":0, "y":1}
    final, t, ev = gillespie(reactions, init)
    return final, t, ev

def main():
    random.seed(0)

    # ---- Test A: Z = X * log2(Y) ----
    X0, Y0 = 6, 32
    targetZ = X0 * int(math.log2(Y0))
    finalA, tA, evA = run_case_A(X0, Y0)
    print("=== Case A: Z = X * log2(Y) ===")
    print("Init: X0 =", X0, "Y0 =", Y0, "Target Z =", targetZ)
    print("Final state:", {k:finalA.get(k,0) for k in ["x","y","w","z"]})
    print("time =", round(tA,3), "events =", evA)
    print()

    # ---- Test B: Y = 2^(log2(X)) ----
    X0 = 32
    targetY = 2 ** int(math.log2(X0))
    finalB, tB, evB = run_case_B(X0)
    print("=== Case B: Y = 2^(log2(X)) ===")
    print("Init: X0 =", X0, "Target Y =", targetY)
    print("Final state:", {k:finalB.get(k,0) for k in ["x","w","y"]})
    print("time =", round(tB,3), "events =", evB)

if __name__ == "__main__":
    main()
